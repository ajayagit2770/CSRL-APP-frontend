# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values
# Get these from: Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: backend base URL for REST API mode.
# Local dev can use /api (Vite proxy). Production (Vercel) should use your Render backend URL:
VITE_API_BASE_URL=https://csrl-app-backed.onrender.com/api
